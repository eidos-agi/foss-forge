# Publish to PyPI via trusted publisher (OIDC).
# Triggered by pushing a version tag: git tag v0.1.0 && git push --tags
#
# Prerequisites:
#   1. Create a "pypi" environment in GitHub repo settings
#   2. Add PyPI as a trusted publisher:
#      - PyPI project name: {{PROJECT_SLUG}}
#      - Owner: {{GITHUB_ORG}}
#      - Repository: {{GITHUB_REPO}}
#      - Workflow: publish.yml
#      - Environment: pypi

name: Publish to PyPI

on:
  push:
    tags: ["v*"]

jobs:
  publish:
    runs-on: ubuntu-latest
    environment: pypi
    permissions:
      id-token: write
      contents: read
    steps:
      - uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install build tools
        run: pip install build

      - name: Build package
        run: python -m build

      - name: Publish to PyPI
        uses: pypa/gh-action-pypi-publish@release/v1
